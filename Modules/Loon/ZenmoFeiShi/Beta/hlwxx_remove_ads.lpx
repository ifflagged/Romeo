#!name=黑料不打烊净化
#!desc=hlwxx_remove_ads
#!author=怎么肥事
#!icon=icon not found
#!tag=Jacob
#!update=2026-05-02

[Rewrite]
^https?:\/\/stats\.kwvprfcr\.xyz - reject
^https?:\/\/mc\.yandex\.ru - reject
^https?:\/\/api1\.cghhqca\.cc\/api\/eventTracking - reject-dict
^https?:\/\/api\.shuifeng\.cc\/api\/eventTracking - reject-dict
^https?:\/\/ads\.zyudkkup\.com\/api\/eventTracking - reject-dict
^https?:\/\/static\.cloudflareinsights\.com\/beacon - reject

[Script]
http-request ^https?:\/\/(?:www\.)?(?:heiliao|hlwxx|hlcx\d*)\.com\/(?!static\/|favicon|api\/|index\/statistics|uploads\/) script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/ZenmoFeiShi/hlwxx_remove_ads/Script-Hub-Org_replace-header.js, timeout=30, tag=replaceHeader, argument=(%5Cr%5Cn)Accept-Encoding%3A.%2B(%5Cr%5Cn)-%3E%241Accept-Encoding%3A%20identity%242

http-response ^https?:\/\/(?:www\.)?(?:heiliao|hlwxx|hlcx\d*)\.com\/(?!static\/|favicon|api\/|index\/statistics|uploads\/) script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/ZenmoFeiShi/hlwxx_remove_ads/ZenmoFeiShi_hlwxx_remove_ads.js, requires-body=true, timeout=60, tag=hlwxx_remove_ads

[MITM]
hostname = *heiliao*, *hlwxx*, *hlcx*, stats.kwvprfcr.xyz, mc.yandex.ru, api1.cghhqca.cc, api.shuifeng.cc, ads.zyudkkup.com, static.cloudflareinsights.com

