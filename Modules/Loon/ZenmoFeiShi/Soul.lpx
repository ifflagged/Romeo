[Rewrite]
^https:\/\/api-a\.soulapp\.cn\/v2\/post\/gift\/list response-body-json-jq '.data = null'
^https:\/\/post\.soulapp\.cn\/hot\/soul\/rank response-body-json-jq '.data = null'
^https:\/\/gateway-mobile-gray\.soulapp\.cn\/mobile\/app\/version\/queryIos response-body-json-jq '.data = null'
^https:\/\/api-chat\.soulapp\.cn\/chat\/limitInfo response-body-json-jq '.data.limit = false'
^https:\/\/post\.soulapp\.cn\/v\d\/post\/homepage\/guide\/card response-body-json-jq '.data = null'
^https:\/\/api-user\.soulapp\.cn\/furion\/position\/content response-body-json-jq '.data = null'
^https:\/\/api-account\.soulapp\.cn\/teenager\/config response-body-json-jq '.data = null'
^https:\/\/47\.110\.187\.87\/winterfell\/(?:v2\/)?getIpByDomain response-body-json-jq '.data = null'
^https:\/\/api-a\.soulapp\.cn\/official\/scene\/module response-body-json-jq '.data = null'
^https:\/\/chat-live\.soulapp\.cn\/chatroom\/chatClassifyRoomList response-body-json-jq '.data.roomList = []'
^https:\/\/api-user\.soulapp\.cn\/v6\/planet\/config response-body-json-jq '.data.gameInfo.gameCards |= map(select(.title != "异世界回响" and .title != "狼人魅影" and .title != "梦想海岛王" and .title != "幻想星球" and .title != "爆弹喵" and .title != "星球实验室" and .title != "兴趣群组" and .title != "群聊派对")) | .data.coreCards |= map(select(.title != "异世界回响" and .title != "狼人魅影" and .title != "梦想海岛王" and .title != "幻想星球" and .title != "爆弹喵" and .title != "星球实验室" and .title != "兴趣群组" and .title != "群聊派对") | if .secondCards then .secondCards |= map(select(.title != "异世界回响" and .title != "狼人魅影" and .title != "梦想海岛王" and .title != "幻想星球" and .title != "爆弹喵" and .title != "星球实验室" and .title != "兴趣群组" and .title != "群聊派对")) else . end | if .style == 2 then .style = 1 else . end)'
^https:\/\/post\.soulapp\.cn\/v2\/post\/recSquare\/subTabs response-body-json-jq '.data |= map(select(.tabType == 7 or .tabType == 6 or .tabType == 2))'
^https:\/\/ssp\.soulapp\.cn\/api\/q - reject-dict
^https:\/\/api-chat\.soulapp\.cn\/chat\/quick\/menu\/v2 - reject-dict
^https:\/\/api-chat\.soulapp\.cn\/chat\/guide\/defaultWord - reject-dict
^https:\/\/api-chat\.soulapp\.cn\/chat\/attach\/menu - reject-dict
^https:\/\/api-chat\.soulapp\.cn\/chat\/entrance\/first - reject-dict
^https:\/\/chat-live\.soulapp\.cn\/live\/planet\/recListV2 - reject-200

[MITM]
hostname = api-account.soulapp.cn, chat-live.soulapp.cn, api-a.soulapp.cn, api-pay.soulapp.cn, gateway-mobile-gray.soulapp.cn, api-chat.soulapp.cn, 120.55.55.115, 120.55.62.124, 121.196.203.183, 47.96.20.45, 47.98.54.106, 118.31.112.221, 8.210.3.170, 47.75.72.47, post.soulapp.cn, api-user.soulapp.cn, ssp.soulapp.cn, 47.110.187.87

