# 2026-03-14 07:41:44
# https://kelee.one/Tool/Loon/Lpx/12306_remove_ads.lpx
# 2025-07-06
# https://github.com/kokoryh/Sparkle/blob/master/release/surge/module/12306.sgmodule

[Rule]
# 放行规则
DOMAIN, ad.12306.cn, DIRECT

[Rewrite]
^https:\/\/ad\.12306\.cn\/ad\/ser\/getAdList$ response-body-json-del materialsList advertParam

[Script]
# 移除12306应用内广告
http-response ^https:\/\/mobile\.12306\.cn\/otsmobile\/app\/mgs\/mgw\.htm$ script-path = https://kelee.one/Resource/JavaScript/12306/12306_remove_ads.js, tag = [铁路12306]移除应用内广告

[MitM]
hostname = ad.12306.cn, mobile.12306.cn