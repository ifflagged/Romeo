[Script]
http-request ^https?:\/\/gql(-fed)?\.reddit\.com script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/ddgksf2013/main/RavelloH_main.js, timeout=60, tag=main

[MITM]
hostname = gql.reddit.com, gql-fed.reddit.com

