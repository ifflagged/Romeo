[Rewrite]
^https:\/\/api\.chenlongtech\.cn\/v\d\/friends\/startInfo$ reject-dict
^https:\/\/api\.chenlongtech\.cn\/v\d\/friends\/indexBanner$ reject-dict
^https:\/\/api\.chenlongtech\.cn\/v\d\/friends\/getPopup reject-dict
^https:\/\/api\.chenlongtech\.cn\/v\d\/friends\/allPopUpConfig$ reject-dict
^https:\/\/api\.chenlongtech\.cn\/v\d\/friends\/advConf$ reject-dict
^https:\/\/api\.chenlongtech\.cn\/v\d\/user\/checkQTSheInsurance$ reject-dict

[Script]
http-response ^https:\/\/api\.chenlongtech\.cn\/v\d\/lover\/productList script-path=https://kelee.one/Resource/JavaScript/Uki/Uki_remove_ads.js, requires-body=true, tag=移除匹配卡横幅

http-response ^https:\/\/api\.chenlongtech\.cn\/v\d\/friends\/closeFriend\/home script-path=https://kelee.one/Resource/JavaScript/Uki/Uki_remove_ads.js, requires-body=true, tag=移除密友横幅

http-response ^https:\/\/api\.chenlongtech\.cn\/v\d\/party\/config$ script-path=https://kelee.one/Resource/JavaScript/Uki/Uki_remove_ads.js, requires-body=true, tag=移除娱乐页面横幅和悬浮窗配置

http-response ^https:\/\/api\.chenlongtech\.cn\/v1\/post\/fetchSearchRecommend$ script-path=https://kelee.one/Resource/JavaScript/Uki/Uki_remove_ads.js, requires-body=true, tag=移除广场搜索填充词

[MitM]
hostname=api.chenlongtech.cn