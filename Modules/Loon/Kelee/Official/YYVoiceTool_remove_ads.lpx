[Rewrite]
^https:\/\/yuyin-api\.baizhanlive\.com\/homepage\/flashscreen\/get\? reject-dict

^https:\/\/yuyin-api\.baizhanlive\.com\/homepage\/homepage\/banner\? reject-dict

