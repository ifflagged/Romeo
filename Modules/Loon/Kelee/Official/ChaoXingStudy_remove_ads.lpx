#!name=学习通去广告
#!desc=移除开屏广告、横幅推广，精简校园补给站频道。
#!openUrl=https://apps.apple.com/app/id977946724
#!author=可莉🅥[https://github.com/luestr/ProxyResource/blob/main/README.md]
#!tag=去广告
#!system=
#!system_version=
#!loon_version=3.4.0(962)
