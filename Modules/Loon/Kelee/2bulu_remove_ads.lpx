[Rewrite]
^https:\/\/helper\.2bulu\.com\/getAppEntranceConfig\? response-body-json-jq '.configData=(.configData|fromjson|del(.adPlatform,.adIntertitialShowType,.adsConfig,.adIntertitialDisplayedLimit,.adSplashShowTypeWhenHotStart,.adIntertitialDayDisplayedMaxCount,.od_adsType,.showMeBaiHeAdView)|tojson)'
^https:\/\/helper\.2bulu\.com\/search\/searchHotKeyList\? - reject-dict
^https:\/\/helper\.2bulu\.com\/promote\/getAppUserModule\? - reject-dict
^https:\/\/helper\.2bulu\.com\/proSpecial\/allData\? - reject-dict

[MITM]
hostname = helper.2bulu.com

