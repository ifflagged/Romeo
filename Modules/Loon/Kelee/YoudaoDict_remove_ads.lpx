[Rewrite]
^https:\/\/dict\.youdao\.com\/homepage\/toolbar\/get\/ response-body-json-del data.vipTag
^https:\/\/dict\.youdao\.com\/vip\/activity\/startup\/ - reject-dict
^https:\/\/dict\.youdao\.com\/vip\/activity\/retention\/configs\? - reject-dict
^https:\/\/dict\.youdao\.com\/vip\/activity\/retention\/match\? - reject-dict
^https:\/\/dict\.youdao\.com\/vip\/user\/paid\/guide\? - reject-dict

[MITM]
hostname = dict.youdao.com

