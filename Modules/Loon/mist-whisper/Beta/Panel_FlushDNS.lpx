#!name=Flush DNS
#!desc=快速清除DNS缓存
#!author=Rabbit-Spec[https://github.com/Rabbit-Spec]
#!icon=icon not found
#!tag=Jacob
#!date=2024-09-09

[Argument]
title=input,"DNS Flush",tag=自定义面板标题。, desc=自定义面板标题。
icon=input,"cube",tag=自定义面板图标,需为有效的SFSymbolName,如不设置则默认。, desc=自定义面板图标,需为有效的SFSymbolName,如不设置则默认。
color=input,"#AFE59A",tag=自定义图标颜色,需为颜色的HEX编码。, desc=自定义图标颜色,需为颜色的HEX编码。

