#!name=芒果TV
#!desc=解锁芒果TV会员，提升画质，移除广告，页面优化。
#!author=WeiGiegie[https://github.com/WeiGiegie],wish[https://github.com/mist-whisper]
#!tag=解锁去广告
#!system=iOS iPadOS
#!system_version=15
#!loon_version=3.4.0(962)
#!homepage=https://kelvinlab.wuyra.com
#!icon=https://resource.wuyra.com/Icon/App_icon/120px/Mango_TV.png
#!date=2026-03-17 11:37:00

[Rewrite]
^https?://mobile.da.mgtv.com\/m\/page reject-dict

[Script]
http-response ^https?:\/\/.*mgtv.com.*(GetUserInfo|module\/list\?_support|app\/bdboot|pullReleaseInfo|floor\/detail|video\/source|entry\?_support).*$ script-path=https://resource.wuyra.com/Script/MangoTV/MangoTV.js, requires-body=true, timeout=60, tag=芒果TV页面优化
http-request ^https?:\/\/mobile-stream\.api\.mgtv\.com\/v1\/video\/source\? script-path=https://resource.wuyra.com/Script/MangoTV/Mangotk.js, requires-body=true, timeout=60, tag=解锁芒果TV会员

[MITM]
hostname=*mgtv.com,hb-boom.api.mgtv.com,*.api.mgtv.com,mobile-stream.api.mgtv.com,hb-boom.api.mgtv.com,mobile-stream.api.mgtv.com,nuc.api.mgtv.com,111.31.104.108, 111.31.104.*, 111.31.104.96, *.api.mgtv.com, iphone.v0.mgtv.com, api.data.mgtv.com, *.*.mgtv.*,