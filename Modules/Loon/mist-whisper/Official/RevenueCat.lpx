[Script]
http-response ^https:\/\/api\.(revenuecat|rc-backup)\.com\/.+\/(receipts$|subscribers\/?(.*?)*$) script-path=https://resource.wuyra.com/Script/Revenuecat/Revenuecat.js, requires-body=true, timeout=60, tag=RevenueCat合集
http-request ^https:\/\/api\.(revenuecat|rc-backup)\.com\/.+\/(receipts$|subscribers\/?(.*?)*$) script-path=https://resource.wuyra.com/Script/Revenuecat/Revenuecat.js, requires-body=true, timeout=60, tag=RevenueCat合集

[MITM]
hostname=api.revenuecat.com, api.rc-backup.com