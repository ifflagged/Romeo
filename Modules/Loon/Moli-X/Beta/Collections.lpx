#!name=Collections
#!desc=Collections
#!icon=icon not found
#!tag=Jacob

[Rewrite]
# ✅🔞PornHub  *.pornhub.com
^https:\/\/(cn|www)\.pornhub\.com\/_xa\/ads - reject-dict

[Script]
# ✅SUB-STORE
http-request ^https?:\/\/sub\.store\/((download)|api\/(preview|sync|(utils\/node-info))) script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/sub-store-org_sub-store-1.min.js, requires-body=true, timeout=60, tag=sub-store-1.min

http-request ^https?:\/\/sub\.store script-path=https://github.com/sub-store-org/Sub-Store/releases/latest/download/sub-store-0.min.js, requires-body=true, timeout=60, tag=sub-store-0.min

# ✅BoxJS
http-request ^https?:\/\/boxjs\.(com|net) script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/chavyleung_chavy.boxjs.js, requires-body=true, timeout=60, tag=chavy.boxjs

# ✅Spotify  ,spclient.wg.spotify.com
http-response ^https:\/\/spclient\.wg\.spotify\.com\/(bootstrap\/v1\/bootstrap|user-customization-service\/v1\/customize)$ script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/app2smile_spotify-proto.js, requires-body=true, binary-body-mode=true, timeout=60, tag=spotify-proto

http-request ^https:\/\/spclient\.wg\.spotify\.com\/(artistview\/v1\/artist|album-entity-view\/v2\/album)\/ script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/app2smile_spotify-json.js, timeout=60, tag=spotify-json

# ✅美图秀秀vip
http-response ^https?:\/\/(h5|api)\.xiuxiu\.meitu\.com\/v\d\/(h\d\/vip|vip|user)\/ script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/Moli-X_MeiTu.js, requires-body=true, timeout=60, tag=MeiTu

# ✅美图秀秀粉钻
http-response ^https:\/\/api\.xiuxiu\.meitu\.com\/v1 script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/Moli-X_MTxiuxiu.js, requires-body=true, timeout=60, tag=MTxiuxiu

# ✅Testflight区域限制+共享
http-request ^https:\/\/testflight\.apple\.com\/v\d\/(app|account|invite)s\/ script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/NobyDa_TestFlightAccount.js, requires-body=true, timeout=60, tag=TestFlightAccount

http-response ^https?:/\/(cn|www)\.pornhub\.com\/($|(view|video).*$) script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/ddgksf2013_pornhub.js, requires-body=true, timeout=60, tag=pornhub

# ✅豆瓣电影 cn-acs.m.cainiao.com, guide-acs.m.taobao.com
http-response ^https://m.douban.com/movie/subject/.+ script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/ddgksf2013_douban.js, requires-body=true, timeout=60, tag=douban

http-request ^https://m.douban.com/movie/subject/.+\?seen=\d script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/ddgksf2013_douban.js, timeout=60, tag=douban

# ✅豆瓣电影和电视剧添加便捷播放按钮(2022.01.28)
http-response ^https?:\/\/m\.douban\.com\/movie\/subject\/\d+\/ script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/I-am-R-E_DouBan.js, requires-body=true, timeout=60, tag=DouBan

# ✅微信跳过中间界面  weixin110.qq.com, security.wechat.com,
http-response ^https\:\/\/(weixin110\.qq|security.wechat)\.com\/cgi-bin\/mmspamsupport-bin\/newredirectconfirmcgi\? script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/zZPiglet_UnblockURLinWeChat.js, requires-body=true, timeout=60, tag=UnblockURLinWeChat

# ✅YouTube字幕+画中画+去广告
http-response ^https:\/\/www.youtube.com\/api\/timedtext.+ script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/Neurogram-R_Dualsub.js, requires-body=true, timeout=60, tag=Dualsub

http-request ^https:\/\/setting.youtube.com\/\?action=(g|s)et script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/Neurogram-R_Dualsub.js, requires-body=true, timeout=60, tag=Dualsub

# ✅Nicegram
http-response ^https?:\/\/restore-access\.indream\.app\/restoreAccess script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/Moli-X_Nicegram.js, requires-body=true, timeout=60, tag=Nicegram

[MITM]
hostname = boxjs.com, boxes.net, sub.store, spclient.wg.spotify.com, appwk.baidu.com, pan.baidu.com, restore-access.indream.app, *wps*, *.xiuxiu.meitu.com, api.xiuxiu.meitu.com, ap*.intsig.net, testflight.apple.com, *.pornhub.com, cupfox.app, *.youtube.com, app.bilibili.com, app.biliapi.net, app.biliintl.com, api.weibo.cn, mapi.weibo.com, *.uve.weibo.com, youtubei.googleapis.com, cn-acs.m.cainiao.com, guide-acs.m.taobao.com, weixin110.qq.com, security.wechat.com, m.douban.com

