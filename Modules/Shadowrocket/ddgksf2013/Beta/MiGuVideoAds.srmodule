#!name=MiGuVideoAds
#!desc=MiGuVideoAds
#!icon=icon not found
#!category=Jacob

[URL Rewrite]
https://.*miguvideo\.com\/request\/sdk - reject-200
https://.*miguvideo\.com\/deliver\/site\/batchMatch\/mergeSpot\/miguvideo - reject-200

[Body Rewrite]
http-response-jq https://.*miguvideo\.com\/recommend-dynamic\/dataSource\/v\d\/recommend '.body.data=[]'
http-response-jq https://.*migu\.cn\/search\/hotword '.body={}'

[Script]
migu.ads = type=http-response, pattern=https://.*miguvideo\.com\/app-management\/v\d\/staticcache\/navigation-list\/miguvideo\/ios, script-path=https://ddgksf2013.top/scripts/migu.ads.js, requires-body=true, max-size=-1, timeout=60

migu.ads = type=http-response, pattern=https://.*miguvideo\.com\/display\/v\d\/static\/PERSONAL_CENTER, script-path=https://ddgksf2013.top/scripts/migu.ads.js, requires-body=true, max-size=-1, timeout=60

[MITM]
hostname = %APPEND% *.miguvideo.com, *.migu.cn

