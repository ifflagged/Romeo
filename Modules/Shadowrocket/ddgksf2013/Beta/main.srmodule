#!name=Reddit 自动翻译
#!desc=自动注入 x-reddit-translations 开启 Reddit App 翻译功能
#!author=RavelloH
#!icon=icon not found
#!category=Jacob

[Script]
main = type=http-request, pattern=^https?:\/\/gql(-fed)?\.reddit\.com, script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/ddgksf2013/main/RavelloH_main.js, timeout=60

[MITM]
hostname = %APPEND% gql.reddit.com, gql-fed.reddit.com

