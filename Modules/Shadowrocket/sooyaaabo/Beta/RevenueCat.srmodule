#!name=RevenueCat
#!desc=RevenueCat系列解锁合集，在设置中选择需要使用的原作者脚本以使用此插件。
#!author=chxm1023[https://github.com/chxm1023], ddgksf2013[https://github.com/ddgksf2013], Guding88[https://github.com/Guding88], Yu9191[https://github.com/Yu9191]
#!icon=icon not found
#!category=Jacob
#!category=解锁会员
#!loon_version=3.3.9(945)
#!homepage=https://loonlab.103516.xyz/Plugin/
#!date=2026-04-01 09:00
#!arguments=RevenueCat-chxm1023:#,RevenueCat-Guding88:#,RevenueCat-ddgksf2013:#,RevenueCat-Yu9191:#
#!arguments-desc=RevenueCat-chxm1023: RevenueCat-chxm1023\n是否启用chxm1023的脚本来解锁RevenueCat系列\n\nRevenueCat-Guding88: RevenueCat-Guding88\n是否启用Guding88的脚本来解锁RevenueCat系列\n\nRevenueCat-ddgksf2013: RevenueCat-ddgksf2013\n是否启用ddgksf2013的脚本来解锁RevenueCat系列\n\nRevenueCat-Yu9191: RevenueCat-Yu9191\n是否启用Yu9191的脚本来解锁RevenueCat系列

[URL Rewrite]
^https:\/\/api\.lianjiu\.fun\/app\/api\/v1\/profile - reject

[Script]
# chxm1023
{{{RevenueCat-chxm1023}}}[RevenueCat]会员解锁响应@chxm1023 = type=http-response, pattern=^https:\/\/api\.(revenuecat|rc-backup)\.com\/.+\/(receipts$|subscribers\/?(.*?)*$), script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/sooyaaabo/RevenueCat/chxm1023_Reheji.js, requires-body=true

{{{RevenueCat-chxm1023}}}[RevenueCat]会员解锁请求@chxm1023 = type=http-request, pattern=^https:\/\/api\.(revenuecat|rc-backup)\.com\/.+\/(receipts$|subscribers\/?(.*?)*$), script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/sooyaaabo/RevenueCat/chxm1023_Reheji.js

# Guding88
{{{RevenueCat-Guding88}}}[RevenueCat]会员解锁响应@Guding88 = type=http-response, pattern=^https?:\/\/api\.(revenuecat|rc-backup)\.com\/v1\/(subscribers\/[^\/]+$|receipts$), script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/sooyaaabo/RevenueCat/Guding88_APPheji_Revenuecat.js, requires-body=true

{{{RevenueCat-Guding88}}}[RevenueCat]会员解锁请求@Guding88 = type=http-request, pattern=^https?:\/\/api\.(revenuecat|rc-backup)\.com\/v1\/(subscribers\/[^\/]+$|receipts$), script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/sooyaaabo/RevenueCat/Guding88_APPheji_Revenuecat.js

# ddgksf2013
{{{RevenueCat-ddgksf2013}}}[RevenueCat]会员解锁响应@ddgksf2013 = type=http-response, pattern=^https:\/\/api\.(revenuecat|rc-backup)\.com\/.+\/(receipts$|subscribers\/?(.*?)*$), script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/sooyaaabo/RevenueCat/ddgksf2013.top_revenuecat.vip.js, requires-body=true

{{{RevenueCat-ddgksf2013}}}[RevenueCat]会员解锁请求@ddgksf2013 = type=http-request, pattern=^https:\/\/api\.(revenuecat|rc-backup)\.com\/.+\/(receipts$|subscribers\/?(.*?)*$), script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/sooyaaabo/RevenueCat/ddgksf2013_deleteHeader.js

# Yu9191
{{{RevenueCat-Yu9191}}}[RevenueCat]会员解锁响应@Yu9191 = type=http-response, pattern=^https:\/\/(api\.revenuecat\.com|api\.rc-backup\.com)\/.+\/(receipts$|subscribers\/[^/]+$), script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/sooyaaabo/RevenueCat/Yu9191_Revenuecat.js, requires-body=true

{{{RevenueCat-Yu9191}}}[RevenueCat]会员解锁请求@Yu9191 = type=http-request, pattern=^https:\/\/(api\.revenuecat\.com|api\.rc-backup\.com)\/.+\/(receipts$|subscribers\/[^/]+$), script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/sooyaaabo/RevenueCat/Yu9191_Revenuecat.js

[MITM]
hostname = %APPEND% api.revenuecat.com, api.rc-backup.com, api.lianjiu.fun

