#!name=Cookie & Task
#!desc=定时每日签到任务，按需开启相应功能即可。
#!author=FoKit[https://github.com/FoKit], Sliverkiss[https://github.com/Sliverkiss], GoodHolidays[https://github.com/GoodHolidays], ZenmoFeiShi[https://github.com/ZenmoFeiShi], NobyDa[https://github.com/NobyDa], ClydeTime[https://github.com/ClydeTime], sooyaaabo[https://github.com/sooyaaabo]
#!icon=icon not found
#!category=Jacob
#!tag=定时任务
#!loon_version=3.5.0(975)
#!homepage=https://loonlab.103516.xyz/Plugin/
#!date=2026-06-26 12:00
#!arguments=Cookie-WeChatPay:true,Task-WeChatPay:true,Cron-WeChatPay:"0 0 9 * * *",Cookie-Weibo:true,Task-Weibo:true,Cron-Weibo:"0 0 9 * * *",Cookie-BilibiliApp:true,Cookie-BilibiliQRCode:false,Task-Bilibili:true,Cron-Bilibili:"0 0 9 * * *"

[Script]
# 微信支付有优惠 - payapp.weixin.qq.com
[微信支付有优惠]领金币Cookie = type=http-response, pattern=https:\/\/payapp\.weixin\.qq\.com\/(coupon-center-user\/home\/login|coupon-center-award\/award\/detail), script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/sooyaaabo/CookieTask/FoKit_wechat_pay_coupon.js, requires-body=true

[微信支付有优惠]领金币Task = type=cron, cronexp={{{Cron-WeChatPay}}}, script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/sooyaaabo/CookieTask/FoKit_wechat_pay_coupon.js

# 微博 - api.weibo.cn
[微博]每日签到Cookie = type=http-request, pattern=^https?:\/\/api\.weibo\.cn\/\d\/users\/show, script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/sooyaaabo/CookieTask/loon.103516.xyz_WeiboCookieTask.js

[微博]每日签到Task = type=cron, cronexp={{{Cron-Weibo}}}, script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/sooyaaabo/CookieTask/loon.103516.xyz_WeiboCookieTask.js

# Bilibili - cm.bilibili.com, m.bilibili.com
[哔哩哔哩App]每日等级任务Cookie = type=http-request, pattern=^https?:\/\/app\.bilibili\.com\/x\/resource\/fingerprint\?, script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/sooyaaabo/CookieTask/ClydeTime_BiliBiliDailyBonus.js

[哔哩哔哩]每日等级任务Task = type=cron, cronexp={{{Cron-Bilibili}}}, script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/sooyaaabo/CookieTask/ClydeTime_BiliBiliDailyBonus.js

[MITM]
hostname = %APPEND% payapp.weixin.qq.com, api.weibo.cn, cm.bilibili.com, m.bilibili.com

