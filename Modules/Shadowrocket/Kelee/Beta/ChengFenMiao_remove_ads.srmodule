[URL Rewrite]
^https:\/\/app\.chengfenmiao\.com\/Listing\/LiveHots\? - reject-dict
^https:\/\/app\.chengfenmiao\.com\/helper\/VersionCheck\? - reject-dict
^https:\/\/app\.chengfenmiao\.com\/item\/closet\? - reject-dict
^https:\/\/app\.chengfenmiao\.com\/Helper\/HotWords\? - reject-dict

[Body Rewrite]
http-response-jq ^https:\/\/app\.chengfenmiao\.com\/helper\/setting\? 'delpaths([["detail_buy_sites"]])'
http-response-jq ^https:\/\/app\.chengfenmiao\.com\/helper\/setting\? 'delpaths([["bottom_sites"]])'

[MITM]
hostname = %APPEND% app.chengfenmiao.com

