http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/risk_entrance\? 'if (getpath(["data"]) | has("single_tool_show_dice_card")) then (setpath(["data","single_tool_show_dice_card"]; false)) else . end'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/risk_entrance\? 'if (getpath(["data"]) | has("single_tool_show_tarot_card")) then (setpath(["data","single_tool_show_tarot_card"]; false)) else . end'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/risk_entrance\? 'if (getpath(["data"]) | has("single_tool_show_bazi_card")) then (setpath(["data","single_tool_show_bazi_card"]; false)) else . end'
