[URL Rewrite]
^https:\/\/api\.cece\.com\/user\/index\/banners\? - reject-dict
^https:\/\/api\.cece\.com\/ask\/ai_chat\/popup\? - reject-dict
^https:\/\/api\.cece\.com\/user\/popup\/ - reject-dict
^https:\/\/api\.cece\.com\/chart\/easter_egg\/popup\? - reject-dict
^https:\/\/api\.cece\.com\/user\/register_task\/notice_task\? - reject-dict
^https:\/\/api\.cece\.com\/ask\/ask\/alert_minus\? - reject-dict
^https:\/\/api\.cece\.com\/msgAsk\/question\/new_coupon_status\? - reject-dict
^https:\/\/api\.cece\.com\/user\/user\/myPageBanner\? - reject-dict
^https:\/\/api\.cece\.com\/live\/recommend\/new_user\? - reject-dict
^https:\/\/api\.cece\.com\/chart\/tools\/get_search_recommend\? - reject-dict
^https:\/\/api\.cece\.com\/user\/rank\/list\? - reject-dict
^https:\/\/api\.cece\.com\/chart\/config\/chart_activity\? - reject-dict

[Body Rewrite]
http-response-jq ^https:\/\/api\.cece\.com\/user\/init\? 'delpaths([["data","launch_img_url"]])'
http-response-jq ^https:\/\/api\.cece\.com\/user\/init\? 'delpaths([["data","launch_goto_url"]])'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/app_config\? 'if (getpath(["data"]) | has("is_new_year")) then (setpath(["data","is_new_year"]; false)) else . end'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/app_config\? 'if (getpath(["data"]) | has("spring_festival")) then (setpath(["data","spring_festival"]; false)) else . end'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/app_config\? 'if (getpath(["data"]) | has("show_feedback_entry")) then (setpath(["data","show_feedback_entry"]; false)) else . end'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/app_config\? 'if (getpath(["data"]) | has("show_course_entry")) then (setpath(["data","show_course_entry"]; false)) else . end'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/app_config\? 'if (getpath(["data"]) | has("show_store_entry")) then (setpath(["data","show_store_entry"]; false)) else . end'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/app_config\? 'if (getpath(["data"]) | has("show_luna")) then (setpath(["data","show_luna"]; false)) else . end'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/app_config\? 'if (getpath(["data"]) | has("show_ead")) then (setpath(["data","show_ead"]; false)) else . end'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/app_config\? 'if (getpath(["data"]) | has("show_ad")) then (setpath(["data","show_ad"]; false)) else . end'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/app_config\? 'if (getpath(["data"]) | has("show_live_filter_tarot")) then (setpath(["data","show_live_filter_tarot"]; false)) else . end'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/app_config\? 'if (getpath(["data"]) | has("community_feed_adswitch")) then (setpath(["data","community_feed_adswitch"]; false)) else . end'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/app_config\? 'if (getpath(["data"]) | has("open_screen_ad_times")) then (setpath(["data","open_screen_ad_times"]; 0)) else . end'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/app_config\? 'if (getpath(["data"]) | has("open_screen_ad_duration")) then (setpath(["data","open_screen_ad_duration"]; 0)) else . end'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/app_config\? 'if (getpath(["data"]) | has("isShowThumbsGif")) then (setpath(["data","isShowThumbsGif"]; false)) else . end'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/app_config\? 'if (getpath(["data"]) | has("teenager_mode_open")) then (setpath(["data","teenager_mode_open"]; false)) else . end'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/app_config\? 'if (getpath(["data"]) | has("flu_log")) then (setpath(["data","flu_log"]; false)) else . end'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/app_config\? 'delpaths([["data","activity_list"]])'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/app_config\? 'delpaths([["data","fortune_ab_config"]])'
http-response-jq ^https:\/\/api\.cece\.com\/chart\/tools\/home_10_tools\? '.data.tools |= map(del(.icon_tip_image))'
http-response-jq ^https:\/\/api\.cece\.com\/user\/index\/tab_list\? '.data.tabs |= map(select(.type != "shop"))'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/risk_entrance\? 'if (getpath(["data"]) | has("ai_fortune_show_ask_tool")) then (setpath(["data","ai_fortune_show_ask_tool"]; false)) else . end'
