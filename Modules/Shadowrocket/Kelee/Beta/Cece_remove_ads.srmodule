http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/risk_entrance\? 'if (getpath(["data"]) | has("single_tool_show_ziwei_card")) then (setpath(["data","single_tool_show_ziwei_card"]; false)) else . end'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/risk_entrance\? 'if (getpath(["data"]) | has("single_tool_show_xingpan_card")) then (setpath(["data","single_tool_show_xingpan_card"]; false)) else . end'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/risk_entrance\? 'if (getpath(["data"]) | has("multi_tool_show_card")) then (setpath(["data","multi_tool_show_card"]; false)) else . end'
http-response-jq ^https:\/\/api\.cece\.com\/common\/app\/risk_entrance\? 'if (getpath(["data"]) | has("ai_ccai_show_multi_tool")) then (setpath(["data","ai_ccai_show_multi_tool"]; false)) else . end'

[Map Local]
^https:\/\/api\.cece\.com\/live\/user\/coupon_tab\? data-type=json data="{"code":0,"msg":""}"

[MITM]
hostname = %APPEND% api.cece.com

