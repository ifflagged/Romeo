[URL Rewrite]
^https:\/\/jz\.wacaijizhang\.com\/api\/banners\/ - reject-dict
^https:\/\/jz\.wacaijizhang\.com\/api\/resource\/universal\/fetch$ - reject-dict
^https:\/\/jz\.wacaijizhang\.com\/activity\/ - reject

[Map Local]
^https:\/\/jz\.wacaijizhang\.com\/sensor\/config\/iOS\.conf\? data-type=text data="{"v":"v2","configs":{"disableSDK":true,"disableDebugMode":true,"supportTransportEncrypt":false}}" header="Content-Type:application/json"

[MITM]
hostname = %APPEND% jz.wacaijizhang.com

