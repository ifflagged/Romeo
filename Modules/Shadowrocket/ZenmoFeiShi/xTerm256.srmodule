[Body Rewrite]
http-response-jq ^https:\/\/buy\.itunes\.apple\.com\/verifyReceipt '.receipt.in_app[].expires_date_ms = "4092599349000" | .latest_receipt_info[].expires_date_ms = "4092599349000" | .pending_renewal_info[].auto_renew_status = "1"'

[MITM]
hostname = %APPEND% buy.itunes.apple.com

