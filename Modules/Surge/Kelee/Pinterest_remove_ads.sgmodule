[Body Rewrite]
http-response-jq ^https:\/\/api\.pinterest\.com\/v3\/feeds\/home\/\? '.data |= map(select(.is_promoted == false or .is_promoted == "false"))'

[MITM]
hostname = %APPEND% api.pinterest.com

