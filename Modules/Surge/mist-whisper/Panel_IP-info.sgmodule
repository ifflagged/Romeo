#!name=节点信息面板
#!desc=展示节点的IP/运营商/所在地
#!author=cc63[https://github.com/cc63]
#!icon=icon not found
#!category=Jacob
#!date=2024-07-02
#!arguments-desc=\n⚙️API序号\n\n1.ip-api.com\n2.ipinfo.io\n3.ipleak.net\n4.ip.sb
#!arguments=API序号:1

[Panel]
IP-info = script-name=IP-info, title="节点信息", content="请刷新",style=info, update-interval=1,no-resolve

[Script]
IP-info = type=generic, script-path=https://resource.wuyra.com/Script/Tools/IP-info/IP-{{{API序号}}}.js,no-resolve, timeout=5

