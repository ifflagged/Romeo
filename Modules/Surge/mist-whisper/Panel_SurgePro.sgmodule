SurgePro = type=generic, script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/mist-whisper/Panel_SurgePro/Rabbit-Spec_SurgePro.js, timeout=10, argument=icon=paperplane.circle&color=#f6c970

