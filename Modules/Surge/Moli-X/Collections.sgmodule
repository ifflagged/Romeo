#!name=Collections
#!desc=Collections
#!icon=icon not found
#!category=Jacob

[Map Local]
# ✅🔞PornHub  *.pornhub.com
^https:\/\/(cn|www)\.pornhub\.com\/_xa\/ads data-type=text data="{}" status-code=200 header="Content-Type:application/json"

[Script]
# ✅SUB-STORE
sub-store-1.min = type=http-request, pattern=^https?:\/\/sub\.store\/((download)|api\/(preview|sync|(utils\/node-info))), script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/sub-store-org_sub-store-1.min.js, requires-body=true, max-size=-1, timeout=60

sub-store-0.min = type=http-request, pattern=^https?:\/\/sub\.store, script-path=https://github.com/sub-store-org/Sub-Store/releases/latest/download/sub-store-0.min.js, requires-body=true, max-size=-1, timeout=60

# ✅BoxJS
chavy.boxjs = type=http-request, pattern=^https?:\/\/boxjs\.(com|net), script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/chavyleung_chavy.boxjs.js, requires-body=true, max-size=-1, timeout=60

# ✅Spotify  ,spclient.wg.spotify.com
spotify-proto = type=http-response, pattern=^https:\/\/spclient\.wg\.spotify\.com\/(bootstrap\/v1\/bootstrap|user-customization-service\/v1\/customize)$, script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/app2smile_spotify-proto.js, requires-body=true, binary-body-mode=true, max-size=-1, timeout=60

spotify-json = type=http-request, pattern=^https:\/\/spclient\.wg\.spotify\.com\/(artistview\/v1\/artist|album-entity-view\/v2\/album)\/, script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/app2smile_spotify-json.js, timeout=60

# ✅美图秀秀vip
MeiTu = type=http-response, pattern=^https?:\/\/(h5|api)\.xiuxiu\.meitu\.com\/v\d\/(h\d\/vip|vip|user)\/, script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/Moli-X_MeiTu.js, requires-body=true, max-size=-1, timeout=60

# ✅美图秀秀粉钻
MTxiuxiu = type=http-response, pattern=^https:\/\/api\.xiuxiu\.meitu\.com\/v1, script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/Moli-X_MTxiuxiu.js, requires-body=true, max-size=-1, timeout=60

# ✅Testflight区域限制+共享
TestFlightAccount = type=http-request, pattern=^https:\/\/testflight\.apple\.com\/v\d\/(app|account|invite)s\/, script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/NobyDa_TestFlightAccount.js, requires-body=true, max-size=-1, timeout=60

pornhub = type=http-response, pattern=^https?:/\/(cn|www)\.pornhub\.com\/($|(view|video).*$), script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/ddgksf2013_pornhub.js, requires-body=true, max-size=-1, timeout=60

# ✅豆瓣电影 cn-acs.m.cainiao.com, guide-acs.m.taobao.com
douban = type=http-response, pattern=^https://m.douban.com/movie/subject/.+, script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/ddgksf2013_douban.js, requires-body=true, max-size=-1, timeout=60

douban = type=http-request, pattern=^https://m.douban.com/movie/subject/.+\?seen=\d, script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/ddgksf2013_douban.js, timeout=60

# ✅豆瓣电影和电视剧添加便捷播放按钮(2022.01.28)
DouBan = type=http-response, pattern=^https?:\/\/m\.douban\.com\/movie\/subject\/\d+\/, script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/I-am-R-E_DouBan.js, requires-body=true, max-size=-1, timeout=60

# ✅微信跳过中间界面  weixin110.qq.com, security.wechat.com,
UnblockURLinWeChat = type=http-response, pattern=^https\:\/\/(weixin110\.qq|security.wechat)\.com\/cgi-bin\/mmspamsupport-bin\/newredirectconfirmcgi\?, script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/zZPiglet_UnblockURLinWeChat.js, requires-body=true, max-size=-1, timeout=60

# ✅YouTube字幕+画中画+去广告
Dualsub = type=http-response, pattern=^https:\/\/www.youtube.com\/api\/timedtext.+, script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/Neurogram-R_Dualsub.js, requires-body=true, max-size=-1, timeout=60

Dualsub = type=http-request, pattern=^https:\/\/setting.youtube.com\/\?action=(g|s)et, script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/Neurogram-R_Dualsub.js, requires-body=true, max-size=-1, timeout=60

# ✅Nicegram
Nicegram = type=http-response, pattern=^https?:\/\/restore-access\.indream\.app\/restoreAccess, script-path=https://github.com/ifflagged/Romeo/raw/main/Modules/JS/Moli-X/Collections/Moli-X_Nicegram.js, requires-body=true, max-size=-1, timeout=60

[MITM]
hostname = %APPEND% boxjs.com, boxes.net, sub.store, spclient.wg.spotify.com, appwk.baidu.com, pan.baidu.com, restore-access.indream.app, *wps*, *.xiuxiu.meitu.com, api.xiuxiu.meitu.com, ap*.intsig.net, testflight.apple.com, *.pornhub.com, cupfox.app, *.youtube.com, app.bilibili.com, app.biliapi.net, app.biliintl.com, api.weibo.cn, mapi.weibo.com, *.uve.weibo.com, youtubei.googleapis.com, cn-acs.m.cainiao.com, guide-acs.m.taobao.com, weixin110.qq.com, security.wechat.com, m.douban.com

